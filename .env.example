# ─────────────────────────────────────────────────────
# Voice AI System — Environment Configuration
# Copy to .env and fill in your values
# ─────────────────────────────────────────────────────

# ── OpenAI (primary LLM) ────────────────────────────
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-4o-mini

# ── Ollama (fallback LLM — runs locally) ────────────
# Install: https://ollama.com  then: ollama pull llama3
OLLAMA_MODEL=llama3
OLLAMA_URL=http://localhost:11434

# ── Server ──────────────────────────────────────────
PORT=8000
LOG_LEVEL=INFO

# ── ASR (Faster-Whisper) ─────────────────────────────
# Options: tiny | base | small | medium | large-v3
WHISPER_MODEL_SIZE=base
# Options: cpu | cuda
WHISPER_DEVICE=cpu

# ── TTS (Piper) ──────────────────────────────────────
TTS_VOICE=en_US-lessac-medium
# Path to piper executable (must be in PATH or specify full path)
PIPER_PATH=piper

# ── RAG ─────────────────────────────────────────────
# Set to true to enable retrieval-augmented generation
RAG_ENABLED=false
KNOWLEDGE_BASE_PATH=rag/knowledge_base
