# ─────────────────────────────────────────────────────
# Voice AI System — Environment Configuration
# Copy to .env and fill in your values
# ─────────────────────────────────────────────────────
# ── Groq (Fast & Free) ──────────────────────────────
# Get free API key: https://console.groq.com/keys
GROQ_API_KEY=your-groq-api-key-here
GROQ_MODEL=llama-3.3-70b-versatile
# ── OpenAI (primary LLM) ────────────────────────────
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-4o-mini

# ── Ollama (fallback LLM — runs locally) ────────────
# Install: https://ollama.com  then: ollama pull llama3
OLLAMA_MODEL=llama3
OLLAMA_URL=http://localhost:11434

# ── Server ──────────────────────────────────────────
PORT=8000
LOG_LEVEL=INFO
ENVIRONMENT=development  # development | production

# ── Production Security ─────────────────────────────
# CORS origins (comma-separated, use * for development only)
CORS_ORIGINS=*
# Trusted hosts (comma-separated, use * for development only)
TRUSTED_HOSTS=*
# Rate limiting (requests per minute per IP)
RATE_LIMIT_REQUESTS=100
# Enable API docs in production (set to false for security)
ENABLE_DOCS=true
DEBUG=false
ACCESS_LOG=true
WORKERS=1

# ── ASR (Faster-Whisper local mode) ───────────────────────
# ASR_MODE: "local" (default, faster-whisper) | "hf" (Hugging Face Gradio Space)
ASR_MODE=local
# Options: tiny | base | small | medium | large-v3
WHISPER_MODEL_SIZE=base
# Options: cpu | cuda
WHISPER_DEVICE=cpu

# ── ASR (HF Gradio Whisper mode) ───────────────────────────
# Used when ASR_MODE=hf  (pip install gradio_client required)
# Space URL: https://huggingface.co/spaces/openai/whisper
HF_WHISPER_SPACE=openai/whisper
# Optional HF token for private spaces / higher rate limits
# HF_TOKEN=your-huggingface-token-here

# ── TTS (Piper) ──────────────────────────────────────
TTS_VOICE=en_US-lessac-medium
# Path to piper executable (must be in PATH or specify full path)
PIPER_PATH=piper

# ── RAG ─────────────────────────────────────────────
# Set to true to enable retrieval-augmented generation
RAG_ENABLED=false
KNOWLEDGE_BASE_PATH=rag/knowledge_base
